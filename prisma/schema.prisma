// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique
  email     String    @unique
  phone     String    @unique
  password  String
  role      Role      @default(USER)
  profile   Profile?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Profile {
  id         Int        @id @default(autoincrement())
  uuid       String     @unique
  bio        String
  avatar     String?
  birth_date DateTime?
  gender     String?
  address    String?
  status     UserStatus @default(ACTIVE)
  userId     Int        @unique
  user       User       @relation(fields: [userId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
}

model RoomType {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique
  name        String    @unique
  description String?
  price       Decimal
  rooms       Room[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model Floor {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique
  name      String    @unique
  capacity  Int
  room      Room[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Room {
  id          Int        @id @default(autoincrement())
  uuid        String     @unique
  name        String     @unique
  description String?
  status      RoomStatus @default(MAINTENANCE)
  typeId      Int
  roomType    RoomType   @relation(fields: [typeId], references: [id])
  floorId     Int
  floor       Floor      @relation(fields: [floorId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
}

enum Role {
  ADMIN
  USER
  GUEST
  STAFF
  NURSE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum RoomStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  OCCUPIED
}
